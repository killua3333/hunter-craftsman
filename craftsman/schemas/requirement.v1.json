{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://craftsman.local/schemas/requirement.v1.json",
  "title": "Agent A Requirement",
  "type": "object",
  "required": ["schema_version", "opportunity_id", "revision", "app", "features"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "opportunity_id": { "type": "string", "minLength": 1 },
    "revision": { "type": "integer", "minimum": 1 },
    "data_quality": {
      "type": "string",
      "enum": ["measured", "assumption", "mixed"],
      "description": "市场结论：实测 / 假设 / 混合"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["query", "source", "snippet"],
        "properties": {
          "query": { "type": "string" },
          "source": { "type": "string" },
          "snippet": { "type": "string" }
        }
      }
    },
    "platform": {
      "type": "object",
      "properties": {
        "target": { "type": "string", "enum": ["android", "ios"] }
      }
    },
    "app": {
      "type": "object",
      "required": ["name", "bundle_id"],
      "properties": {
        "name": { "type": "string" },
        "bundle_id": { "type": "string", "pattern": "^[a-zA-Z0-9.-]+$" },
        "application_id": { "type": "string", "pattern": "^[a-zA-Z0-9._]+$" },
        "version": { "type": "string", "default": "1.0.0" },
        "build": { "type": "string", "default": "1" },
        "min_ios": { "type": "string", "default": "17.0" },
        "min_android_sdk": { "type": "string", "default": "24" }
      }
    },
    "features": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "title"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["list", "form", "detail", "tab_root"] },
          "title": { "type": "string" },
          "items": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "core_logic": {
      "type": "object",
      "properties": {
        "persistence": {
          "type": "string",
          "enum": ["none", "UserDefaults", "SwiftData", "SharedPreferences"]
        },
        "description": { "type": "string" }
      }
    },
    "ui_layout": {
      "type": "object",
      "properties": {
        "navigation": { "type": "string", "enum": ["stack", "tab", "single"] },
        "screens": { "type": "array" }
      }
    },
    "branding": {
      "type": "object",
      "properties": {
        "primary_color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "accent_color": { "type": "string" },
        "icon_text": { "type": "string", "maxLength": 2 }
      }
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "store": {
      "type": "object",
      "properties": {
        "subtitle": { "type": "string" },
        "description": { "type": "string" },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "privacy_url": { "type": "string", "format": "uri" }
      }
    },
    "applied_rules": {
      "type": "array",
      "items": { "type": "string" }
    },
    "budget": {
      "type": "object",
      "properties": {
        "max_features": { "type": "integer", "default": 8 },
        "max_hours": { "type": "number", "default": 2.0 }
      }
    },
    "agent_a_context": {
      "type": "object",
      "properties": {
        "summary": { "type": "string" },
        "estimated_complexity": { "type": "string" },
        "open_questions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "reasons": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}

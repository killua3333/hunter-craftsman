<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ app_name }}</title>
  <style>
    :root { --primary: {{ primary_color }}; --bg: #F2F2F7; }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #1a1a2e; min-height: 100vh; display: flex;
      align-items: center; justify-content: center; padding: 24px;
    }
    .phone {
      width: 390px; max-width: 100%; min-height: 640px; background: var(--bg);
      border-radius: 40px; box-shadow: 0 24px 80px rgba(0,0,0,.45);
      overflow: hidden; display: flex; flex-direction: column;
    }
    .nav { padding: 48px 20px 12px; font-size: 28px; font-weight: 700; }
    .list { flex: 1; padding: 0 16px 24px; overflow-y: auto; }
    .section-title { font-size: 13px; color: #8E8E93; margin: 16px 8px 8px; text-transform: uppercase; }
    .row {
      background: #fff; padding: 14px 16px; border-radius: 10px;
      margin-bottom: 8px; display: flex; align-items: center; justify-content: space-between;
    }
    .row button {
      border: none; background: none; color: var(--primary); cursor: pointer; font-size: 14px;
    }
    .add-bar {
      display: flex; gap: 8px; padding: 12px 16px 24px; background: var(--bg);
      border-top: 1px solid #E5E5EA;
    }
    .add-bar input {
      flex: 1; padding: 10px 12px; border: 1px solid #E5E5EA; border-radius: 8px; font-size: 16px;
    }
    .add-bar button {
      padding: 10px 16px; border: none; border-radius: 8px; background: var(--primary);
      color: #fff; font-weight: 600; cursor: pointer;
    }
    .subtitle { padding: 0 20px 8px; color: #8E8E93; font-size: 14px; }
  </style>
</head>
<body>
  <div class="phone">
    <div class="nav" style="color: var(--primary)">{{ app_name }}</div>
    {% if subtitle %}<div class="subtitle">{{ subtitle }}</div>{% endif %}
    <div class="list">
      <div class="section-title">{{ app_name }}</div>
      <div id="itemList"></div>
    </div>
    <div class="add-bar">
      <input id="newItem" placeholder="添加条目…" />
      <button id="btnAdd">添加</button>
    </div>
  </div>
  <script>
    const STORAGE_KEY = 'craftsman_list_{{ app_name | replace(" ", "_") }}';
    const seed = {{ items | tojson }};
    let items = JSON.parse(localStorage.getItem(STORAGE_KEY) || 'null') || seed.slice();

    function render() {
      const el = document.getElementById('itemList');
      el.innerHTML = items.map((text, i) => `
        <div class="row">
          <span>${text.replace(/</g,'&lt;')}</span>
          <button data-i="${i}">删除</button>
        </div>`).join('');
      el.querySelectorAll('button').forEach(btn => {
        btn.onclick = () => {
          items.splice(Number(btn.dataset.i), 1);
          localStorage.setItem(STORAGE_KEY, JSON.stringify(items));
          render();
        };
      });
    }

    document.getElementById('btnAdd').onclick = () => {
      const v = document.getElementById('newItem').value.trim();
      if (!v) return;
      items.push(v);
      document.getElementById('newItem').value = '';
      localStorage.setItem(STORAGE_KEY, JSON.stringify(items));
      render();
    };

    render();
  </script>
</body>
</html>

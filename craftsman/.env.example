# HTTP
HOST=127.0.0.1
PORT=8791

# 同机 Agent A：反馈 JSON 写入此目录
CALLBACK_DIR=./callbacks
API_TOKEN=
SECRET_PROVIDER=env_file_fallback
SECRET_STORE_DIR=./secrets
# 若使用 file provider，可在 SECRET_STORE_DIR 下放置 API_TOKEN / WEBHOOK_SECRET / DEEPSEEK_API_KEY 等文件
CONTRACT_DEFAULT_VERSION=1.0
CONTRACT_SUPPORTED_VERSIONS=1.0
ARTIFACT_URI_MODE=object
ARTIFACT_OBJECT_PREFIX=object://local
# 可选 Webhook（与文件双写）
# WEBHOOK_URL=http://127.0.0.1:9000/craftsman/feedback
# WEBHOOK_SECRET=change-me
WEBHOOK_MANDATORY=false

# DeepSeek（推荐）
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
# 反馈 Agent A（Gate 语义评审）
DEEPSEEK_CHAT_MODEL=deepseek-chat
# 写码 + Reflexion 修错
DEEPSEEK_PRO_MODEL=deepseek-v4-pro
LLM_PRICE_CHAT_INPUT_PER_1K=0
LLM_PRICE_CHAT_OUTPUT_PER_1K=0
LLM_PRICE_PRO_INPUT_PER_1K=0
LLM_PRICE_PRO_OUTPUT_PER_1K=0
ALERT_WINDOW_SIZE=20
ALERT_MIN_SAMPLES=5
ALERT_FAILURE_RATE_THRESHOLD=0.5
ALERT_TIMEOUT_RATE_THRESHOLD=0.3
ALERT_DURATION_THRESHOLD_RATIO=0.9
RELEASE_REQUIRE_HUMAN_APPROVAL=true
RELEASE_REQUIRE_POLICY_CHECKS=true
AUDIT_RETENTION_DAYS=14
AUDIT_REPLAY_LIMIT=500
NATIVE_BACKEND_POOL=local-macos
NATIVE_BACKEND_POOL_STRATEGY=round_robin
EXECUTION_IMAGE_REF=ghcr.io/hunter-craftsman/craftsman:py312-latest

# Agent C (Publisher) — Android release
PUBLISHER_DRY_RUN=true
ANDROID_RELEASE_TRACK=internal
# 真上架时改为 false，并完成 docs/play-console-setup-checklist.md
# PUBLISHER_DRY_RUN=false
# RELEASE_REQUIRE_HUMAN_APPROVAL=false

# 可选：固定包名（默认从 manifest.json 读取）
# GOOGLE_PLAY_PACKAGE_NAME=com.yourbrand.app

# Release signing（真打包必填）
# ANDROID_KEYSTORE_PATH=./secrets/release.jks
# ANDROID_KEYSTORE_PASSWORD=
# ANDROID_KEY_ALIAS=release
# ANDROID_KEY_PASSWORD=

# Play API（真上传必填）
# GOOGLE_PLAY_SERVICE_ACCOUNT_FILE=./secrets/play-sa.json
# 或 GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# 兼容旧变量（未设 DEEPSEEK_API_KEY 时可用）
# OPENAI_API_KEY=sk-...

# 流水线
MAX_REFLEXION_ROUNDS=5
MAX_IMPLEMENTATION_SECONDS=7200
LLM_REQUEST_TIMEOUT_SECONDS=120
JOB_WORKER_COUNT=1
PUBLISHER_SUBMIT_TIMEOUT_SECONDS=1800
SIMULATOR_NAME=iPhone 16

# Windows 开发机可跳过 Xcode/Fastlane
SKIP_XCODEBUILD=true
SKIP_FASTLANE=true

# Gate：soft=先跑通再迭代；strict=旧版严格拦截
GATE_MODE=soft
GATE_AUTO_ACCEPT=true
# Android Gradle 编译（Docker auto 或本机 SDK）
# SKIP_GRADLE_BUILD=true 强制跳过编译（demo 模式）
# SKIP_GRADLE_BUILD=false
ANDROID_BUILD_BACKEND=auto
DOCKER_ANDROID_IMAGE=hunter-craftsman/android-builder
DOCKER_GRADLE_TIMEOUT_SECONDS=1800
ANDROID_SMOKE_TEST=auto
ANDROID_SMOKE_TIMEOUT_SECONDS=600
ANDROID_SMOKE_MAX_ROUNDS=2

# 隐私政策 Cloudflare Pages（默认 dry-run；真部署需 CF token）
PRIVACY_DEPLOY_DRY_RUN=true
PRIVACY_CONTACT_EMAIL=privacy@example.com
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

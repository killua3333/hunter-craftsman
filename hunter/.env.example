# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# DEEPSEEK_API_BASE=https://api.deepseek.com/v1
HUNTER_MODEL_NAME=deepseek-chat

# Tavily 网页搜索（web_search / play_search / autopilot 必需）https://tavily.com
TAVILY_API_KEY=tvly-your-tavily-key-here

# Craftsman 反馈目录（hunter feedback sync / hunter-weekly）
# CRAFTSMAN_CALLBACK_DIR=../craftsman/callbacks

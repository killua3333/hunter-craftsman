[Unit]
Description=Craftsman Agent B Service
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/hunter-agent/craftsman
EnvironmentFile=/etc/hunter-craftsman/craftsman.env
ExecStart=/opt/hunter-agent/.venv/bin/python -m craftsman.cli serve --host 0.0.0.0 --port 8791
Restart=always
RestartSec=5
User=www-data
Group=www-data

[Install]
WantedBy=multi-user.target
